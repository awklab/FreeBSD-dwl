# Dracula Color Palette
background-color=#282a36
text-color=#f8f8f2
border-color=#754eb5
progress-color=source #6272a4

# Border and Style
border-size=1
border-radius=0
font=monospace 9

# Behavior (Make it stay)
default-timeout=5000
ignore-timeout=1

[urgency=low]
border-color=#6272a4

[urgency=high]
border-color=#ff5555
default-timeout=0
